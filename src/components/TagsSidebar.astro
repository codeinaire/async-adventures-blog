---
interface Props {
  tags: string[]
  tagCounts?: { [key: string]: number }
}

const { tags, tagCounts } = Astro.props
---

{
  tags && tags.length > 0 && (
    <div class="relative text-foreground/90 bg-foreground/6 xl:bg-transparent px-8 xl:pr-2 py-6 mt-5 xl:mt-0 w-full rounded-xl border-3 xl:border-none border-accent/10 xl:sticky xl:top-10 xl:basis-[280px] 2xl:basis-[340px] xl:order-2 xl:shrink-0">
      <h3 class="text-accent font-semibold mb-4 text-sm">Tags</h3>
      <div class="flex flex-wrap gap-2">
        {tags.sort().map((tag) => {
          const count = tagCounts?.[tag] || 0
          return (
            <a
              class="inline-block px-3 py-1 text-xs bg-accent/10 text-accent rounded-full hover:bg-accent/20 transition-colors"
              href={`/tags/${encodeURIComponent(tag)}`}
            >
              #{tag}
              {count > 0 && ` (${count})`}
            </a>
          )
        })}
      </div>
    </div>
  )
}
