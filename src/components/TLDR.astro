---
interface Props {
  content: string
}

const { content } = Astro.props

// Simple markdown to HTML conversion for basic formatting
function markdownToHtml(markdown: string): string {
  return markdown
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/^- (.*$)/gim, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(.*)$/gm, '<p>$1</p>')
    .replace(/<p><\/p>/g, '')
    .replace(/<p><ul>/g, '<ul>')
    .replace(/<\/ul><\/p>/g, '</ul>')
}

const htmlContent = markdownToHtml(content)
---

<details
  class="relative text-foreground/90 bg-foreground/6 px-8 py-6 w-full rounded-xl border-3 border-accent/10 mb-6"
>
  <summary
    class="list-none marker:hidden marker:content-[''] before:content-['>'] before:text-accent before:font-semibold before:absolute before:left-3 cursor-pointer"
    >TLDR</summary
  >
  <div class="prose prose-sm max-w-none mt-4">
    <div set:html={htmlContent} />
  </div>
</details>

<style>
  details[open] summary:before {
    transform: rotate(90deg);
  }
</style>
